    /\ state' = responded
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ event_queue' = event_queue
    /\ ResponseChannel_queue' = ResponseChannel_queue \o <<[type |-> "Result", arg0 |-> 1, arg1 |-> 42]>>
    /\ UNCHANGED <<RequestChannel_queue, queryId>>

Next ==
