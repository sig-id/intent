\* Transition actions
listening_receive_query ==
    /\ state = listening
    /\ state' = processing
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ event_queue' = event_queue
    /\ RequestChannel_queue' = Tail(RequestChannel_queue)
    /\ UNCHANGED <<ResponseChannel_queue, queryId>>

processing_send_result ==
