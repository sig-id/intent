\* @type: <<Str, Int, Seq(Str), Seq({ type: Str }), Bool, Bool>>;
vars == <<state, pc, history, event_queue, account_active, password_valid>>

Init ==
    /\ state = idle
    /\ pc = 0
    /\ history = <<>>
    /\ event_queue = <<>>
    /\ account_active = FALSE
    /\ password_valid = FALSE

\* Transition actions
idle_submit ==
    /\ state = idle
    /\ state' = verifying
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ event_queue' = event_queue
    /\ UNCHANGED <<account_active, password_valid>>

verifying_ok ==
    /\ state = verifying
    /\ (password_valid /\ account_active)
    /\ state' = authenticated
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ event_queue' = event_queue
    /\ UNCHANGED <<account_active, password_valid>>

verifying_deny ==
    /\ state = verifying
    /\ (~(password_valid) \/ ~(account_active))
    /\ state' = denied
    /\ pc' = pc + 1
    /\ history' = Append(history, state)
    /\ event_queue' = event_queue
    /\ UNCHANGED <<account_active, password_valid>>

Next ==
    \/ idle_submit
    \/ verifying_ok
    \/ verifying_deny
    \/ UNCHANGED vars

\* Stuttering step (system does nothing)
Stutter ==
    UNCHANGED vars

Spec ==
    /\ Init
    /\ [][Next]_vars

\* Type invariant
TypeOK ==
    /\ state \in States
    /\ pc \in Nat
    \* history: checked via HistoryConsistent (Seq(States) unsupported by Apalache)

\* Terminal states
TerminalStates == {authenticated, denied}

\* Once in terminal state, cannot leave
TerminalStable ==
    (state \in TerminalStates) => (state' \in TerminalStates)

\* State invariant for Apalache trace generation
NotTerminated ==
    state \notin TerminalStates

\* History length matches step count
HistoryConsistent ==
    Len(history) = pc

\* Liveness: Eventually reaches a terminal state
Liveness ==
    <>(state \in {authenticated, denied})

\* Deadlock freedom: From every non-terminal state, some action is enabled
DeadlockFree ==
    [](state \notin TerminalStates => ENABLED(Next))

\* Reachability helpers for model checking
CanReach_idle == <>(state = idle)
CanReach_verifying == <>(state = verifying)
CanReach_authenticated == <>(state = authenticated)
CanReach_denied == <>(state = denied)

